-- 🧩 Load Rayfield UI
local success, Rayfield = pcall(function() 
    return loadstring(game:HttpGet('https://sirius.menu/rayfield'))() 
end)

if not success then warn("Gagal load Rayfield!") return end

local Window = Rayfield:CreateWindow({
    Name = "Zoo Admin Sniper v6",
    LoadingTitle = "Loading Admin Potion Shop...",
    LoadingSubtitle = "by Tegar",
    ConfigurationSaving = {Enabled = false}
})

-- 📑 Definisi Tab
local Tab = Window:CreateTab("Sniper Shop", nil)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AdminRE = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("AdminAbuseRE")
local Shared = require(ReplicatedStorage:WaitForChild("Shared"))
local ProductUtil = Shared("GameProductUtility")
local Player = game.Players.LocalPlayer

-- 🛠️ Fungsi Helper buat Beli
local function buyItem(id, method)
    if method == "coin" then
        AdminRE:FireServer({
            ["event"] = "coinbuy",
            ["product"] = id
        })
    elseif method == "gem" then
        AdminRE:FireServer({
            ["event"] = "gembuy",
            ["product"] = id
        })
    elseif method == "robux" then
        pcall(function() ProductUtil:BuyGameProduct(Player, id) end)
    end
    Rayfield:Notify({Title = "Purchase Sent", Content = "ID: " .. id .. " via " .. method, Duration = 2})
end

---

Tab:CreateSection("🧪 Admin Potions & Boosts")

-- List Item dari Gambar + Request
local boosts = {
    {n = "Speed Hourglass", id = "Admin_SpeedUp"},
    {n = "Hatch Potion", id = "Admin_HatchPotion"},
    {n = "Coin Potion", id = "Admin_CoinPotion"}, -- Prediksi ID
    {n = "Luck Potion", id = "Admin_LuckPotion"}   -- Prediksi ID
}

for _, item in pairs(boosts) do
    Tab:CreateLabel(item.n)
    Tab:CreateButton({
        Name = "Buy " .. item.n .. " (Coin)",
        Callback = function() buyItem(item.id, "coin") end,
    })
    Tab:CreateButton({
        Name = "Buy " .. item.n .. " (Gem)",
        Callback = function() buyItem(item.id, "gem") end,
    })
    Tab:CreateSection("---")
end

Tab:CreateSection("🐾 Admin Pets (Special)")

local pets = {
    {n = "Rylen", id = "Admin_Pet"},
    {n = "Admin Pet 2", id = "Admin_Pet2"}
}

for _, pet in pairs(pets) do
    Tab:CreateButton({
        Name = "Buy " .. pet.n .. " (Robux/Auto)",
        Callback = function() buyItem(pet.id, "robux") end,
    })
end

Rayfield:Notify({Title = "V6 Active!", Content = "Potion Sniper Ready!", Duration = 5})
