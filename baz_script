local Shared = require(game.ReplicatedStorage:WaitForChild("Shared"))
local GameUI = Shared("GameUI")
local Player = game.Players.LocalPlayer

local function tryOpenSecretMenu()
    local found = false
    
    -- Scan seluruh Workspace untuk mencari "Setting" yang punya ScreenName
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v.Name == "Setting" and v:GetAttribute("ScreenName") then
            local screenName = v:GetAttribute("ScreenName")
            found = true
            
            print("🚀 Target Ketemu: " .. v:GetFullName())
            print("Opening Screen: " .. tostring(screenName))
            
            -- Eksekusi buka menu
            local success, err = pcall(function()
                GameUI:OpenScreen(Player, screenName, {})
            end)
            
            if success then
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "Bypass Berhasil!",
                    Text = "Menu " .. screenName .. " Terbuka!",
                    Duration = 5
                })
            else
                warn("Gagal buka menu: " .. tostring(err))
            end
        end
    end
    
    if not found then
        print("❌ Gak nemu objek 'Setting' dengan Attribute 'ScreenName'.")
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Error",
            Text = "Menu Rahasia belum di-load di Workspace!",
            Duration = 5
        })
    end
end

-- Langsung jalankan fungsi
tryOpenSecretMenu()
