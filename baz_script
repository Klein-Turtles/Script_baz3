-- 🧩 Load Rayfield UI
local success, Rayfield = pcall(function() 
    return loadstring(game:HttpGet('https://sirius.menu/rayfield'))() 
end)

if not success then warn("Gagal load Rayfield!") return end

local Window = Rayfield:CreateWindow({
    Name = "Zoo Premium Hub v4",
    LoadingTitle = "Bypassing Secret Events...",
    LoadingSubtitle = "by Tegar",
    ConfigurationSaving = {Enabled = false}
})

-- 📑 Definisi Tab
local MainTab = Window:CreateTab("Admin Events", nil)
local Shared = require(game.ReplicatedStorage:WaitForChild("Shared"))
local GameUI = Shared("GameUI")
local Player = game.Players.LocalPlayer

MainTab:CreateSection("Secret Menu Bypasser")

-- 🛠️ Fungsi Utama (Bypass)
local function tryOpenSecretMenu()
    local found = false
    
    -- Scan seluruh Workspace untuk mencari "Setting" yang punya ScreenName
    for _, v in pairs(game.Workspace:GetDescendants()) do
        if v.Name == "Setting" and v:GetAttribute("ScreenName") then
            local screenName = v:GetAttribute("ScreenName")
            found = true
            
            print("🚀 Target Ketemu: " .. v:GetFullName())
            
            -- Eksekusi buka menu
            local success, err = pcall(function()
                GameUI:OpenScreen(Player, screenName, {})
            end)
            
            if success then
                Rayfield:Notify({
                    Title = "Bypass Berhasil!",
                    Content = "Menu " .. tostring(screenName) .. " Terbuka!",
                    Duration = 5
                })
            else
                warn("Gagal buka menu: " .. tostring(err))
            end
        end
    end
    
    if not found then
        Rayfield:Notify({
            Title = "Gagal",
            Content = "Menu rahasia belum di-load di map ini!",
            Duration = 5
        })
    end
end

-- 🛒 Tombol Eksekusi
MainTab:CreateButton({
    Name = "🔓 Force Open Admin/Secret Menu",
    Info = "Membuka menu shop rahasia yang tersembunyi di map",
    Callback = function()
        tryOpenSecretMenu()
    end,
})

MainTab:CreateSection("Experimental")

MainTab:CreateButton({
    Name = "👁️ Show Hidden Admin UI (Billboard)",
    Info = "Menampilkan tulisan melayang di atas area rahasia",
    Callback = function()
        -- Kita paksa attribute AdminAbuse aktif di HP kita biar BillboardGui muncul
        pcall(function()
            game.Workspace:SetAttribute("AdminAbuseId", Player.UserId)
            game.Workspace:SetAttribute("AdminAbuseGM", true)
            Rayfield:Notify({Title = "Visual On", Content = "Cek sekeliling map untuk tanda melayang!", Duration = 5})
        end)
    end,
})

Rayfield:Notify({
    Title = "Ready!",
    Content = "Tab Admin Events siap digunakan!",
    Duration = 5
})
