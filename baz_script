-- 🧩 Load Rayfield UI
local success, Rayfield = pcall(function() 
    return loadstring(game:HttpGet('https://sirius.menu/rayfield'))() 
end)

if not success then warn("Gagal load Rayfield!") return end

local Window = Rayfield:CreateWindow({
    Name = "Zoo Admin Pet Sniper",
    LoadingTitle = "Targeting Rylen...",
    LoadingSubtitle = "by Tegar",
    ConfigurationSaving = {Enabled = false}
})

local Tab = Window:CreateTab("Sniper", nil)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local AdminRE = ReplicatedStorage:WaitForChild("Remote"):WaitForChild("AdminAbuseRE")
local Shared = require(ReplicatedStorage:WaitForChild("Shared"))
local ProductUtil = Shared("GameProductUtility")
local Player = game.Players.LocalPlayer

Tab:CreateSection("Target: Admin_Pet (Rylen)")

-- 💰 BELI PAKE KOIN (Direct Remote)
Tab:CreateButton({
    Name = "💰 Buy Admin_Pet (COIN)",
    Callback = function()
        AdminRE:FireServer({
            ["event"] = "coinbuy",
            ["product"] = "Admin_Pet"
        })
        Rayfield:Notify({Title = "Snipe Sent", Content = "Mencoba beli Rylen via Coin", Duration = 3})
    end,
})

-- 💵 BELI PAKE ROBUX (Product Utility)
Tab:CreateButton({
    Name = "💵 Buy Admin_Pet (ROBUX)",
    Callback = function()
        pcall(function()
            ProductUtil:BuyGameProduct(Player, "Admin_Pet")
        end)
    end,
})

